#
# MySQL 8.4 compatible config for Lando (replaces symfony recipe mysql8.cnf)
#

[mysqld]
default-storage-engine = innodb

key_buffer_size         = 384M
max_allowed_packet      = 32M
thread_stack            = 400K
thread_cache_size       = 8
read_rnd_buffer_size    = 8M
myisam_sort_buffer_size = 64M
table_open_cache        = 512
sort_buffer_size        = 2M
read_buffer_size        = 2M

# expire_logs_days removed in MySQL 8.4; replaced by binlog_expire_logs_seconds
binlog_expire_logs_seconds = 864000

# innodb_log_file_size deprecated in MySQL 8.4; use innodb_redo_log_capacity
innodb_redo_log_capacity  = 104857600
innodb_flush_log_at_trx_commit = 0
innodb_buffer_pool_size   = 384M
innodb_log_buffer_size    = 4M
innodb_file_per_table     = 1
innodb_open_files         = 256
innodb_io_capacity        = 512
innodb_flush_method       = O_DIRECT
innodb_thread_concurrency = 8
innodb_lock_wait_timeout  = 127

[mysqldump]
quick
quote-names
max_allowed_packet = 32M

[mysql]

[isamchk]
key_buffer_size  = 384M
sort_buffer_size = 256M
read_buffer      = 2M
write_buffer     = 2M
