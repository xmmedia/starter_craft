<script>
    /* this adds the font-size, line-height, letter-spacing, and margin values to the tables above */
    const plUpdateHeadings = () => {
        const rootStyles = getComputedStyle(document.documentElement);
        const rootFs = parseFloat(rootStyles.fontSize);

        function toPx(val) {
            if (!val) return null;
            val = val.trim();
            if (val.endsWith('rem')) return parseFloat(val) * rootFs;
            if (val.endsWith('px')) return parseFloat(val);
            return null;
        }

        function flatRules(ruleList) {
            return [...ruleList].flatMap(rule =>
                rule.cssRules ? flatRules(rule.cssRules) : [rule]
            );
        }

        function buildLookup(filterFn) {
            const map = {};
            [...document.styleSheets].flatMap(sheet => {
                try { return flatRules(sheet.cssRules); } catch(e) { return []; }
            }).filter(rule => rule.selectorText === ':root')
              .forEach(rule => {
                [...rule.style].filter(filterFn).forEach(name => {
                    const px = toPx(rootStyles.getPropertyValue(name));
                    if (px !== null) {
                        const key = Math.round(px * 100) / 100;
                        if (!map[key]) map[key] = name;
                    }
                });
            });
            return map;
        }

        const fontSizeVars   = buildLookup(n => n.startsWith('--text-') && !n.slice(7).includes('--'));
        const lineHeightVars = buildLookup(n => (n.startsWith('--text-') && n.includes('--line-height')) || n.startsWith('--leading-'));
        const trackingVars   = buildLookup(n => n.startsWith('--tracking-'));
        const spacingUnit    = toPx(rootStyles.getPropertyValue('--spacing'));

        function fmtWithVar(computedVal, lookup) {
            const px = parseFloat(computedVal);
            if (isNaN(px)) return computedVal;
            const varName = lookup[Math.round(px * 100) / 100];
            return varName ? `${varName} (${computedVal})` : computedVal;
        }

        function fmtSpacing(computedVal, twPrefix) {
            const px = parseFloat(computedVal);
            if (isNaN(px)) return computedVal;
            if (px === 0) return '0';
            if (spacingUnit > 0) {
                const steps = px / spacingUnit;
                const rounded = Math.round(steps * 4) / 4;
                if (Math.abs(rounded - steps) < 0.01) return `${twPrefix}${rounded} (${computedVal})`;
            }
            return computedVal;
        }

        function populate(el, values) {
            const s = getComputedStyle(el);
            values[0].textContent = fmtWithVar(s.fontSize, fontSizeVars);
            values[1].textContent = fmtWithVar(s.lineHeight, lineHeightVars);
            values[2].textContent = fmtWithVar(s.letterSpacing, trackingVars);
            values[3].textContent = fmtSpacing(s.marginTop, 'mt-');
            values[4].textContent = fmtSpacing(s.marginBottom, 'mb-');
        }

        document.querySelectorAll('#pl-headings tbody tr').forEach((row) => {
            populate(row.querySelector('h1, h2, h3, h4, h5, h6'), row.querySelectorAll('td:not(:first-child)'));
        });
        document.querySelectorAll('#pl-headings-mobile > div').forEach((block) => {
            populate(block.querySelector('h1, h2, h3, h4, h5, h6'), block.querySelectorAll('span'));
        });
    };

    window.addEventListener('load', plUpdateHeadings);
    window.addEventListener('resize', plUpdateHeadings);
</script>

