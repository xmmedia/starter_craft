            <label for="pattern-library-text">Read-only field</label>
            <input type="text" readonly id="pattern-library-text">
        </div>

        <div class="sm:flex">
            <div class="field-wrap w-1/2 mr-2">
                <label for="pattern-library-full_width-1">First field</label>
