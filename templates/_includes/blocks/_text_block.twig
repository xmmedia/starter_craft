{% set classes = [blockWidth(block)] %}

{% if block.textVerticalAlign == 'center' %}
    {% set classes = classes | merge(['flex flex-col justify-center']) %}
{% endif %}

{% if block.textAlign == 'textCenter' %}
    {% set classes = classes | merge(['text-center']) %}
{% elseif block.textAlign == 'textCenterMobile' %}
    {% set classes = classes | merge(['text-center', 'blocks-wrap:text-left']) %}
{% endif %}

{% set classes = classes | merge(block.classes | explodeClass) %}

<div class="text-block-wrap {{ classes | join(' ') }}"{% if block.elementId %} id="{{ block.elementId }}"{% endif %}>
    <div>{{ block.textBlock }}</div>
</div>
