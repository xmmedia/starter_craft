{% set classes = [blockWidth(block)] %}

{% if block.headingStyle != 'default' %}
    {% set classes = classes | merge([block.headingStyle | string]) %}
{% endif %}

{% if block.fullWidth == false %}
    {% set classes = classes | merge(['heading-full-width']) %}
{% endif %}

{% if block.textAlign == 'textCenter' %}
    {% set classes = classes | merge(['mx-auto', 'text-center']) %}
{% elseif block.textAlign == 'textCenterMobile' %}
    {% set classes = classes | merge(['text-center', 'blocks-wrap:text-left']) %}
{% endif %}

{% if block.uppercase %}
    {% set classes = classes | merge(['uppercase']) %}
{% endif %}

{% if block.classes %}
    {% set classes = classes | merge(block.classes | explodeClass) %}
{% endif %}

{% set heading = block.heading | heading_striptags %}
{% if block.headingLink %}
    {% set heading %}
        <a href="{{ block.headingLink.value }}">{{ heading }}</a>
    {% endset %}
{% endif %}

{# if adjusted, review other uses #}
{{ heading(block.headingLevel.value | default(2), {
    html: heading,
    id: block.elementId,
    class: classes,
}) }}
