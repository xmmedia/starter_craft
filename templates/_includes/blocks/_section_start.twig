{% set classes = [] %}

{% if block.spacing == '40' %}
    {% set classes = classes | merge(['py-30', 'lg:py-40']) %}
{% elseif block.spacing == '30' %}
    {% set classes = classes | merge(['py-30']) %}
{% elseif block.spacing == '60' %}
    {% set classes = classes | merge(['py-30', 'lg:py-60']) %}
{% elseif block.spacing == '20' %}
    {% set classes = classes | merge(['py-20']) %}
{% endif %}

{% if block.bgColor != 'white' %}
    {% set classes = classes | merge(['bg-' ~ block.bgColor]) %}
{% endif %}

{% if block.classes %}
    {% set classes = classes | merge(block.classes | explodeClass) %}
{% endif %}

<!-- >>> section start >>> -->
<section class="{{ classes | join(' ') }}"{% if block.elementId %} id="{{ block.elementId }}"{% endif %}>
