<div class="grid grid-cols-3 gap-8">
    {% for post in posts %}
        <article class="p-6 border border-gray-400">
            {% if post.featureImage.one() %}
                {{ image(post.featureImage.one()) }}
            {% endif %}

            <h2>{{ post.title }}</h2>

            <time datetime="{{ post.postDate|atom }}">{{ post.postDate|date }}</time>

            {{ post.summary|md }}

            <a href="{{ post.url }}">Continue Reading</a>
        </article>
    {% endfor %}
</div>
