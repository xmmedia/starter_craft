{% macro bg_style_block(image, imageTransform, className, uniqueClassAppend, selectorSuffix='') %}
    {% if image %}
        {% set _image = image.getUrlsBySize(['1x', '2x', '3x'], imageTransform) %}
        {% set _selector = ".#{className}--#{uniqueClassAppend}#{selectorSuffix}" %}

        {% css %}
            {{ _selector }} {
                background-image: url("{{ _image['1x'] }}");
            }
            @media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
                {{ _selector }} {
                    background-image: url("{{ _image['2x'] }}");
                }
            }
            @media (-webkit-min-device-pixel-ratio: 3), (min-resolution: 288dpi) {
                {{ _selector }} {
                    background-image: url("{{ _image['3x'] }}");
                }
            }
        {% endcss %}
    {% endif %}
{% endmacro %}
