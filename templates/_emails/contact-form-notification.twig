<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ formName ? formName ~ ' form' : 'Website form' }} submission</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f4f5; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f5; padding:32px 16px;">
    <tr>
        <td align="center">
            <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:8px; overflow:hidden; border:1px solid #e4e4e7;">
                <tr>
                    <td style="background-color:#18181b; padding:24px 32px;">
                        <p style="margin:0; font-size:12px; letter-spacing:0.05em; text-transform:uppercase; color:#a1a1aa;">{{ siteName }}</p>
                        <h1 style="margin:4px 0 0; font-size:20px; line-height:1.3; color:#ffffff;">
                            New {{ formName ? formName | lower : 'website' }} form submission
                        </h1>
                    </td>
                </tr>

                <tr>
                    <td style="padding:24px 32px 8px;">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <td valign="middle" style="padding:6px 0; font-size:13px; color:#71717a; width:120px; vertical-align:middle;">Name</td>
                                <td valign="middle" style="padding:6px 0; font-size:16px; color:#18181b; vertical-align:middle;">{{ fromName ?: '—' }}</td>
                            </tr>
                            <tr>
                                <td valign="middle" style="padding:6px 0; font-size:13px; color:#71717a; vertical-align:middle;">Email</td>
                                <td valign="middle" style="padding:6px 0; font-size:16px; vertical-align:middle;">
                                    <a href="mailto:{{ fromEmail }}" style="color:#2563eb; text-decoration:none;">{{ fromEmail }}</a>
                                </td>
                            </tr>
                            {% for label, value in fields %}
                                <tr>
                                    <td valign="middle" style="padding:6px 0; font-size:13px; color:#71717a; vertical-align:middle;">{{ label }}</td>
                                    <td valign="middle" style="padding:6px 0; font-size:16px; color:#18181b; vertical-align:middle;">{{ value ?: '—' }}</td>
                                </tr>
                            {% endfor %}
                        </table>
                    </td>
                </tr>

                {% if body %}
                    <tr>
                        <td style="padding:16px 32px 32px;">
                            <p style="margin:0 0 8px; font-size:13px; color:#71717a;">Message</p>
                            <div style="padding:16px; background-color:#f4f4f5; border-radius:6px; font-size:16px; line-height:1.6; color:#18181b; white-space:pre-wrap;">{{ body }}</div>
                        </td>
                    </tr>
                {% endif %}

                <tr>
                    <td style="padding:16px 32px; background-color:#fafafa; border-top:1px solid #e4e4e7;">
                        <p style="margin:0; font-size:12px; line-height:1.6; color:#a1a1aa;">
                            Sent from the {{ formName ?: 'contact' }} form{% if pageName %} on “{{ pageName }}”{% endif %}{% if pageUrl %} &middot; <a href="{{ pageUrl }}" style="color:#a1a1aa;">{{ pageUrl }}</a>{% endif %}.
                            Reply to this email to respond directly to {{ fromName ?: 'the sender' }}.
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
