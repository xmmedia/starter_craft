<!DOCTYPE html>
<html lang="{{ craft.app.language }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block page_title_wrap %}{% block page_title %}{% endblock %}{{ siteInformation.companyName }}{% endblock %}</title>

    {% block head %}
        {% block canonical %}
            <link rel="canonical" href="{{ craft.app.request.absoluteUrl }}">
        {% endblock %}

        {# @todo add fonts here #}

        {{ craft.vite.script("public/js/src/public.js", false) }}
    {% endblock %}

    {{ head() }}

    {% block favicons %}
        {% include '_includes/_favicons.twig' %}
    {% endblock %}

    {% block analytics %}
        {% if craft.app.config.custom.gaTrackingId %}
            <script async src="https://www.googletagmanager.com/gtag/js?id={{ craft.app.config.custom.gaTrackingId }}"></script>
            <script>
                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());

                gtag('config', '{{ craft.app.config.custom.gaTrackingId }}');
            </script>
        {% endif %}
    {% endblock %}
</head>
<body{% if body_attributes is defined %}{{ body_attributes }}{% endif %}>
<div>
    {% block body %}
        {% block header %}
            {% set menuItems = menus.menuHeader.all() %}

            <header class="header">
                <div class="w-content flex flex-wrap justify-between items-center">
                    <a href="/">
                        <img src="/images/logo.svg" fetchPriority="high" width="150" height="154" alt="{{ siteInformation.companyName }}">
                    </a>

                    <nav class="hidden md:block" aria-label="Main">
                        <ul class="flex flex-nowrap gap-8 p-0 list-none">
                            {% for menuItem in menuItems %}
                                <li class="m-0">
                                    <a href="{{ menuItem.menuLink.url }}">{{ menuItem.menuLabel }}</a>
                                </li>
                            {% endfor %}
                        </ul>
                    </nav>

                    {% if menus.mainMenuButton %}
                        <a href="{{ menus.mainMenuButton.url }}" class="button hidden md:inline-block">
                            {{ menus.mainMenuButton.label }}
                        </a>
                    {% endif %}

                    {# the command/commandfor attributes open the dialog without JS; see menu.js for the fallback #}
                    <button type="button"
                            class="header-menu_toggle md:hidden"
                            command="show-modal"
                            commandfor="mobile-menu"
                            aria-label="Open menu">
                        <svg width="24" height="24" aria-hidden="true">
                            <use href="{{ craft.vite.asset('/images/icons-public.svg') }}#menu"></use>
                        </svg>
                    </button>

                    {% include '_includes/_social_media.twig' %}
                </div>
            </header>

            <dialog id="mobile-menu" class="header-mobile-menu" aria-label="Menu">
                <div class="flex justify-end">
                    <button type="button"
                            class="header-menu_toggle"
                            command="close"
                            commandfor="mobile-menu"
                            autofocus
                            aria-label="Close menu">
                        <svg width="24" height="24" aria-hidden="true">
                            <use href="{{ craft.vite.asset('/images/icons-public.svg') }}#close"></use>
                        </svg>
                    </button>
                </div>

                <nav class="header-mobile-menu_scroll" aria-label="Mobile menu">
                    <ul class="flex flex-col gap-4 list-none">
                        {% for menuItem in menuItems %}
                            <li class="m-0">
                                <a href="{{ menuItem.menuLink.url }}">{{ menuItem.menuLabel }}</a>
                            </li>
                        {% endfor %}
                    </ul>

                    {% if menus.mainMenuButton %}
                        <a href="{{ menus.mainMenuButton.url }}" class="button mt-8">{{ menus.mainMenuButton.label }}</a>
                    {% endif %}
                </nav>
            </dialog>
        {% endblock header %}

        {% block content_wrap %}
            <main>
                {% block content %}
                {% endblock content %}
            </main>
        {% endblock content_wrap %}

        {% block footer %}
            <footer class="footer">
                {% include '_includes/_social_media.twig' %}

                <div class="text-sm">
                    ©{{ 'now' | date('Y') }} {{ siteInformation.companyName }} All Rights Reserved.
                </div>
            </footer>
        {% endblock footer %}
    {% endblock body %}
</div>

{% block javascripts %}
    {% if craft.vite.devServerRunning() %}
        <script defer src="/js/svgxuse.min.js"></script>
    {% endif %}
{% endblock %}
</body>
</html>

